# StockFox Environment Configuration

# Mock data mode (default: true)
# Set to 'false' to use real CMOTS APIs instead of mock data
VITE_USE_MOCK_DATA=true

# CMOTS API Token (required when VITE_USE_MOCK_DATA=false)
# Used by Vite dev proxy AND Vercel serverless function
# Get your token from your CMOTS account
CMOTS_API_TOKEN=your_api_token_here
