# StockFox Environment Configuration

# CMOTS API Token (required for all data fetching)
# Used by Vite dev proxy AND Vercel serverless function
# Get your token from your CMOTS account
CMOTS_API_TOKEN=your_api_token_here

# DhanHQ API Token (optional — enables price data fallback)
# When CMOTS price data is unavailable, DhanHQ provides historical OHLCV as fallback
# Get your token from https://dhanhq.co/
DHAN_ACCESS_TOKEN=your_dhan_token_here

# IndianAPI.in API Key (optional — enables fundamental data fallback)
# Provides annual P&L, balance sheet, cash flow, ratios (12+ years depth)
# Get your key from https://indianapi.in/
INDIANAPI_KEY=your_indianapi_key_here
